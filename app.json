{
  "expo": {
    "name": "run-nimbus",
    "slug": "run-nimbus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "appEnv": "development",
      "admobIosAppId": "",
      "admobAndroidAppId": "",
      "admobInterstitialIos": "",
      "admobInterstitialAndroid": "",
      "supabaseUrl": "",
      "supabaseAnonKey": "",
      "revenuecatIosKey": "",
      "revenuecatAndroidKey": "",
      "eas": {
        "projectId": "6d8892fa-3016-4516-b47a-4f67e4b7801b"
      }
    }
  }
}
