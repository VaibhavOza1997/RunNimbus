# Run Nimbus — Environment Variables
# Copy this file to .env and fill in real values for local dev.
# NEVER commit .env to source control.
# Production secrets must be configured via EAS Secrets (see README).

# App Environment
APP_ENV=development

# Ad Unit IDs (TODO: [ADS] replace with real AdMob IDs before release)
ADMOB_IOS_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX
ADMOB_ANDROID_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX
ADMOB_INTERSTITIAL_IOS=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
ADMOB_INTERSTITIAL_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# Supabase (TODO: [SUPABASE] populate when backend is provisioned)
# WARNING: SUPABASE_ANON_KEY goes to SecureStore at runtime — never bake into bundle
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# RevenueCat (TODO: [IAP] populate when RevenueCat project created)
REVENUECAT_IOS_KEY=appl_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
REVENUECAT_ANDROID_KEY=goog_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
